(footprint "BMP390_LGA-10" (version 20221018) (generator pcbnew)
  (layer "F.Cu")
  (descr "BMP390 Barometric Pressure Sensor, LGA-10, 2.0x2.0x0.75mm, Metal Lid")
  (tags "BMP390 BMP388 pressure sensor LGA-10 2x2mm")
  (attr smd)
  (fp_text reference "U**" (at 0 -2) (layer "F.SilkS")
    (effects (font (size 1 1) (thickness 0.15)))
  )
  (fp_text value "BMP390" (at 0 2) (layer "F.Fab")
    (effects (font (size 1 1) (thickness 0.15)))
  )
  (fp_text user "${REFERENCE}" (at 0 0) (layer "F.Fab")
    (effects (font (size 0.5 0.5) (thickness 0.08)))
  )
  
  ;; Package outline - Courtyard
  (fp_line (start -1.1 -1.1) (end 1.1 -1.1) (stroke (width 0.05) (type solid)) (layer "F.CrtYd"))
  (fp_line (start 1.1 -1.1) (end 1.1 1.1) (stroke (width 0.05) (type solid)) (layer "F.CrtYd"))
  (fp_line (start 1.1 1.1) (end -1.1 1.1) (stroke (width 0.05) (type solid)) (layer "F.CrtYd"))
  (fp_line (start -1.1 1.1) (end -1.1 -1.1) (stroke (width 0.05) (type solid)) (layer "F.CrtYd"))
  
  ;; Fabrication layer
  (fp_line (start -1 -1) (end -1 1) (stroke (width 0.1) (type solid)) (layer "F.Fab"))
  (fp_line (start -1 1) (end 1 1) (stroke (width 0.1) (type solid)) (layer "F.Fab"))
  (fp_line (start 1 1) (end 1 -1) (stroke (width 0.1) (type solid)) (layer "F.Fab"))
  (fp_line (start 1 -1) (end -1 -1) (stroke (width 0.1) (type solid)) (layer "F.Fab"))
  
  ;; Pin 1 indicator (chamfer)
  (fp_line (start -1 -0.6) (end -0.6 -1) (stroke (width 0.1) (type solid)) (layer "F.Fab"))
  
  ;; Silk screen outline
  (fp_line (start -1.05 -1.05) (end 1.05 -1.05) (stroke (width 0.12) (type solid)) (layer "F.SilkS"))
  (fp_line (start 1.05 -1.05) (end 1.05 1.05) (stroke (width 0.12) (type solid)) (layer "F.SilkS"))
  (fp_line (start 1.05 1.05) (end -1.05 1.05) (stroke (width 0.12) (type solid)) (layer "F.SilkS"))
  (fp_line (start -1.05 1.05) (end -1.05 -1.05) (stroke (width 0.12) (type solid)) (layer "F.SilkS"))
  
  ;; Pin 1 dot
  (fp_circle (center -0.7 -0.7) (end -0.6 -0.7) (stroke (width 0.15) (type solid)) (fill none) (layer "F.SilkS"))
  
  ;; Pads - LGA-10, 0.5mm pitch, 2.0x2.0mm package
  ;; Pin 1 - GND (bottom-left)
  (pad "1" smd rect (at -0.75 -0.5) (size 0.3 0.4) (layers "F.Cu" "F.Paste" "F.Mask")
    (solder_mask_margin 0.05) (solder_paste_margin -0.025))
  ;; Pin 2 - VDDIO
  (pad "2" smd rect (at -0.75 0) (size 0.3 0.4) (layers "F.Cu" "F.Paste" "F.Mask")
    (solder_mask_margin 0.05) (solder_paste_margin -0.025))
  ;; Pin 3 - SDO
  (pad "3" smd rect (at -0.75 0.5) (size 0.3 0.4) (layers "F.Cu" "F.Paste" "F.Mask")
    (solder_mask_margin 0.05) (solder_paste_margin -0.025))
  ;; Pin 4 - INT2
  (pad "4" smd rect (at -0.75 0.9) (size 0.3 0.25) (layers "F.Cu" "F.Paste" "F.Mask")
    (solder_mask_margin 0.05) (solder_paste_margin -0.025))
  
  ;; Pin 5 - VDD (top side)
  (pad "5" smd rect (at -0.45 0.9) (size 0.3 0.25) (layers "F.Cu" "F.Paste" "F.Mask")
    (solder_mask_margin 0.05) (solder_paste_margin -0.025))
  
  ;; Pin 6 - INT1 (top side)
  (pad "6" smd rect (at 0.45 0.9) (size 0.3 0.25) (layers "F.Cu" "F.Paste" "F.Mask")
    (solder_mask_margin 0.05) (solder_paste_margin -0.025))
  
  ;; Pin 7 - SCL (right side)
  (pad "7" smd rect (at 0.75 0.5) (size 0.3 0.4) (layers "F.Cu" "F.Paste" "F.Mask")
    (solder_mask_margin 0.05) (solder_paste_margin -0.025))
  ;; Pin 8 - SDA
  (pad "8" smd rect (at 0.75 0) (size 0.3 0.4) (layers "F.Cu" "F.Paste" "F.Mask")
    (solder_mask_margin 0.05) (solder_paste_margin -0.025))
  ;; Pin 9 - CSB
  (pad "9" smd rect (at 0.75 -0.5) (size 0.3 0.4) (layers "F.Cu" "F.Paste" "F.Mask")
    (solder_mask_margin 0.05) (solder_paste_margin -0.025))
  ;; Pin 10 - GND (bottom-right)
  (pad "10" smd rect (at 0.75 -0.9) (size 0.3 0.25) (layers "F.Cu" "F.Paste" "F.Mask")
    (solder_mask_margin 0.05) (solder_paste_margin -0.025))
  
  ;; 3D model reference
  (model "${KIPRJMOD}/3D/BMP390.step"
    (offset (xyz 0 0 0))
    (scale (xyz 1 1 1))
    (rotate (xyz 0 0 0))
  )
)
